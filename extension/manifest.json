{
  "manifest_version": 3,
  "name": "Gomega Visual Feedback",
  "version": "0.1.0",
  "description": "Pin visual feedback on real websites without installing a site script.",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Gomega Feedback"
  }
}
